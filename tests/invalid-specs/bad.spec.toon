# status, duplicate business-rule id, no assumptions block (warning)

feature:
  id: FEAT-1
  name: Broken

requirement:
  actor: User

inputs[3]{name,type,required}:
  a,string,true
  b,int,false

outputs:
  success:
    status: 201
  errors[1]{code,status,when}:
    NOT_FOUND,quatro,thing missing

business-rules[2]{id,rule}:
  BR-001,rule one
  BR-001,rule one again
